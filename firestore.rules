rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /weatherLogs/{logId} {
      allow create: if isSignedIn() && isValidId(logId) &&
        request.resource.data.keys().hasAll(['location', 'timestamp', 'actualTemp', 'predictedTemp']) &&
        request.resource.data.actualTemp is number &&
        request.resource.data.predictedTemp is number;
      allow read: if isSignedIn();
    }

    match /modelPerformance/{locationId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(locationId);
    }

    match /userPreferences/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
